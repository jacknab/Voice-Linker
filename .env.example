# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=disable

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Twilio ──────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567

# ─── ElevenLabs ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fallback voice used when no category-specific voice is set (required)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Voice for Male-Male (MM) system prompts — overrides ELEVENLABS_VOICE_ID
ELEVENLABS_VOICE_ID_MM=your_mm_voice_id_here

# Voice for Male-Women (MW) system prompts — overrides ELEVENLABS_VOICE_ID
ELEVENLABS_VOICE_ID_MW=your_mw_voice_id_here

# Roger's dedicated voice for engagement/personality audio — overrides ELEVENLABS_VOICE_ID
ELEVENLABS_VOICE_ID_ROGER=your_roger_voice_id_here

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to "false" to hide the Mailboxes & Personal Ads option from the IVR main menu
ENABLE_MAILBOX=true

# ─── IVR Script ───────────────────────────────────────────────────────────────
# Path (relative to server/) to the IVR module that exports registerVoiceRoutes(app).
# Two variants are available:
#   ./ivr-default     — full IVR including Mailboxes & Personal Ads menu option
#   ./ivr-no-mailbox  — same IVR but with Mailboxes & Personal Ads permanently removed
IVR_FILE=./ivr-default
