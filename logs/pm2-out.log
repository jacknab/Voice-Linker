,"usesV3":false,"followUpAction":null,"cooldownSeconds":360,"requiredMoods":[],"minAttentionDrain":3,"maxAttentionDrain":10,"audioFilename":null,"audioUrl":null},{"id":"reward_extra_05","category":"reward","tone":"seductive","lineText":"Every message you send is a chance at something real. You are playing this perfectly.","v3Text":null,"usesV3":false,"followUpAction":null,"cooldownSeconds":300,"requiredMoods":[],"minAttentionDrain":3,"maxAttentionDrain":10,"audioFilename":null,"audioUrl":null},{"id":"roger_01","category":"idle","tone":"comedic","lineText":"Just so you know, Roger is watching. Not in a weird way. In a supportive way.","v3Text":null,"usesV3":false,"followUpAction":null,"cooldownSeconds":160,"requiredMoods":[],"minAttentionDrain":3,"maxAttentionDrain":10,"audioFilename":null,"audioUrl":null},{"id":"roger_02","category":"picky","tone":"comedic","lineText":"You know how they say all the good ones are taken? They are not. They are right here on this line.","v3Text":null,"usesV3":false,"followUpAction":"suggest_send_message","cooldownSeconds":200,"requiredMoods":[],"minAttentionDrain":4,"maxAttentionDrain":10,"audioFilename":null,"audioUrl":null},{"id":"roger_03","category":"flirty","tone":"comedic","lineText":"What if I told you the next profile is exactly your type? You'll never know unless you listen.","v3Text":null,"usesV3":false,"followUpAction":null,"cooldownSeconds":180,"requiredMoods":[],"minAttentionDrain":4,"maxAttentionDrain":10,"audioFilename":null,"audioUrl":null},{"id":"roger_04","category":"idle","tone":"comedic","lineText":"You have been very still. Which means either you are very relaxed or you are overthinking everything. Either way — say hello to someone.","v3Text":"[sighs] You have been very still. [curious] Which means either you are very relaxed or you are overthinking everything. [warmly] Either way — say hello to someone.","usesV3":true,"followUpAction":"suggest_send_message","cooldownSeconds":200,"requiredMoods":[],"minAttentionDrain":5,"maxAttentionDrain":10,"audioFilename":null,"audioUrl":null},{"id":"roger_05","category":"picky","tone":"comedic","lineText":"Eleven skips. I have started giving them all nicknames. Skip. Skipped. Also Skipped. Another Skip.","v3Text":"[chuckles] Eleven skips. [deadpan] I have started giving them all nicknames. Skip. Skipped. Also Skipped. Another Skip.","usesV3":true,"followUpAction":null,"cooldownSeconds":260,"requiredMoods":[],"minAttentionDrain":6,"maxAttentionDrain":10,"audioFilename":null,"audioUrl":null},{"id":"roger_06","category":"reengagement","tone":"comedic","lineText":"You know what I have never heard anyone regret? Sending a message. Just something to think about.","v3Text":"[warmly] You know what I have never heard anyone regret? [playfully] Sending a message. Just something to think about.","usesV3":true,"followUpAction":"suggest_send_message","cooldownSeconds":260,"requiredMoods":[],"minAttentionDrain":6,"maxAttentionDrain":10,"audioFilename":null,"audioUrl":null},{"id":"roger_07","category":"flirty","tone":"comedic","lineText":"Somewhere on this line is a guy who would absolutely love to get a message from you. He just does not know it yet.","v3Text":"[mischievously] Somewhere on this line is a guy who would absolutely love to get a message from you. [whispers] He just does not know it yet.","usesV3":true,"followUpAction":"suggest_send_message","cooldownSeconds":200,"requiredMoods":[],"minAttentionDrain":4,"maxAttentionDrain":10,"audioFilename":null,"audioUrl":null},{"id":"roger_08","category":"dominant","tone":"comedic","lineText":"At some point browsing stops being productive and starts being an avoidance strategy. You might be there. Send a message.","v3Text":null,"usesV3":false,"followUpAction":"suggest_send_message","cooldownSeconds":300,"requiredMoods":[],"minAttentionDrain":7,"maxAttentionDrain":10,"audioFilename":null,"audioUrl":null}]
